APP_NAME=RoomCanvas AI
APP_VERSION=1.0.0
DEBUG=false
DATABASE_URL=sqlite:///./storage/interior_ai.db
UPLOAD_DIR=./storage/uploads
GENERATED_DIR=./storage/generated
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
MAX_UPLOAD_SIZE_MB=10
ACTIVE_ANALYSIS_PROVIDER=gemini
ACTIVE_GENERATION_PROVIDER=replicate
GEMINI_API_KEY=your_gemini_api_key_here
REPLICATE_API_TOKEN=your_replicate_token_here
UPSTASH_REDIS_URL=your_upstash_url_here
UPSTASH_REDIS_TOKEN=your_upstash_token_here
GEMINI_TIMEOUT_SECONDS=60
REPLICATE_TIMEOUT_SECONDS=45
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_CREDENTIALS_PATH=backend/credentials/firebase-admin.json
