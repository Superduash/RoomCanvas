# ──────────────────────────────────────────────────────────────────────────────
# RoomCanvas AI — Backend Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit the real .env file to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=RoomCanvas AI
APP_VERSION=1.0.0
DEBUG=false

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite for local development. Change to PostgreSQL for production:
# DATABASE_URL=postgresql://user:password@localhost:5432/roomcanvas
DATABASE_URL=sqlite:///./storage/interior_ai.db

# ── Storage ───────────────────────────────────────────────────────────────────
UPLOAD_DIR=./storage/uploads
GENERATED_DIR=./storage/generated

# ── API / Security ────────────────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
MAX_UPLOAD_SIZE_MB=10

# ── AI Pipeline ───────────────────────────────────────────────────────────────
ACTIVE_ANALYSIS_PROVIDER=gemini
ACTIVE_GENERATION_PROVIDER=replicate

# API Keys
GEMINI_API_KEY=your_gemini_api_key_here
REPLICATE_API_TOKEN=your_replicate_token_here

# Timeouts
GEMINI_TIMEOUT_SECONDS=20
REPLICATE_TIMEOUT_SECONDS=45
