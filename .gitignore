# ──────────────────────────────────────────────────────────────────────────────
# RoomCanvas AI — .gitignore
# ──────────────────────────────────────────────────────────────────────────────

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
.eggs/
dist/
build/
develop-eggs/
/lib/
/lib64/
wheels/
sdist/
var/
parts/
pip-log.txt
pip-delete-this-directory.txt

# Python caches
*.pyc
*.pyo

# Environment managers
.python-version

# Virtual environments
backend/venv/
venv/
.venv/
env/

# Test / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.hypothesis/
coverage.xml
nosetests.xml
*.cover

# ── Node / Frontend ───────────────────────────────────────────────────────────
node_modules/
frontend/dist/
frontend/build/
.npm/

# Vite
.vite/

# ── Environment files & Credentials ───────────────────────────────────────────
.env
.env.*
!.env.example

backend/.env
backend/.env.*
backend/render.env
!backend/.env.example

frontend/.env
frontend/.env.*
frontend/vercel.env
!frontend/.env.example

# Firebase service account and credentials
backend/credentials/
backend/credentials/*.json
firebase-admin*.json

# ── SQLite & Database ─────────────────────────────────────────────────────────
*.db
*.sqlite3
*.db-journal
*.db-shm
*.db-wal
*.sqlite3-journal

# ── Storage (generated images & uploads) — keep folder structure ──────────────
backend/storage/uploads/
backend/storage/control_images/
backend/storage/generated/
!backend/storage/uploads/.gitkeep
!backend/storage/control_images/.gitkeep
!backend/storage/generated/.gitkeep

# ── IDE & Editor ──────────────────────────────────────────────────────────────
.vscode/*
!.vscode/settings.json
.idea/
*.swp
*.swo

# ── OS generated ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# macOS
.AppleDouble
.LSOverride

# Windows
ehthumbs.db

# ── Logs & Caches ─────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.eslintcache
.stylelintcache

# Build caches
.cache/
tmp/
temp/

# Logs
logs/

# Runtime
*.pid

# ── Export Reports ────────────────────────────────────────────────────────────
export_output.txt
Frontend.txt
Backend.txt
code_export.txt
full_audit_out.txt

# Architecture review & planning docs (not project source)
roomcanvas_architecture_review.md
AI_Interior_Design_13Day_Plan_v2.md
